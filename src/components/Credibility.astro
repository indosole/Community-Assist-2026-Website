---
import cred from '../data/credibility.json';
---

<!-- ============ 2 · Credibility band ============ -->
<section class="cred section section--tight" aria-label="Our impact in numbers">
  <div class="wrap">
    <div class="cred-stats">
      {cred.stats.map((s, i) => (
        <div class={`stat reveal${i > 0 ? ` d${i}` : ''}`}>
          <div class="stat-num">{s.accent ? <span class="accent">{s.num}</span> : s.num}</div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
    <div class="cred-logos reveal">
      <p class="ll-label">{cred.partnersLabel}</p>
      {/* First 6 are the biggest sponsors (founding partners + champion tier) — shown larger as a lead line. */}
      <div class="logo-row logo-row--lead">
        {cred.partnerLogos.slice(0, 6).map((l) => (
          <img class="plogo plogo--lead" src={l.src} width={l.width} height={l.height} alt={l.alt} loading="lazy" />
        ))}
      </div>
      <div class="logo-row">
        {cred.partnerLogos.slice(6).map((l) => (
          <img class="plogo" src={l.src} width={l.width} height={l.height} alt={l.alt} loading="lazy" />
        ))}
      </div>
    </div>
  </div>
</section>
